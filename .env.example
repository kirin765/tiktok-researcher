DATABASE_URL=postgresql+psycopg://viral:viral@postgres:5432/viral_factory
REDIS_URL=redis://redis:6379/0
STORAGE_DIR=/data/storage
EXPORT_DIR=/data/exports

PROVIDER_DEFAULT=apify
APIFY_TOKEN=
APIFY_ACTOR_ID=clockworks/tiktok-scraper
APIFY_ACTOR_TIMEOUT=120
APIFY_DISCOVERY_ACTOR_ID=
APIFY_DISCOVERY_TIMEOUT=120
DISCOVERY_SYNC_MAX_RESULTS=120
APIFY_MAX_CONCURRENT_REQUESTS=3

ENABLE_CONTENT_ANALYSIS=false
ENABLE_ASR=false
CLEANUP_SOURCE_VIDEO=false

BRIEF_WINDOW_DAYS=7
BRIEF_TOP_K=100
WORKER_SYNC=false
MAX_SNAPSHOT_ATTEMPTS=5
RETRY_BASE_SECONDS=60
RETRY_CAP_SECONDS=3600
LOG_LEVEL=info
